{
  "name": "json-tools",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview --port 4321",
    "astro": "astro",
    "typecheck": "astro check && tsc --noEmit",
