    "@codemirror/view": "^6.42.1",
    "@preact/signals": "^2.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^5.18.1",
    "codemirror": "^6.0.2",
    "preact": "^10.29.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
