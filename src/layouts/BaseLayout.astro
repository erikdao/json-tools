---
import '../styles/global.css';
const { title = 'jsontools' } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="bg-amber-50 text-stone-900 font-sans">
    <slot />
  </body>
</html>
