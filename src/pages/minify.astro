---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TabStrip from '../components/TabStrip.astro';
import Workspace from '../components/Workspace';
---
<BaseLayout title="Minify JSON — jsontools"
            description="Compress JSON to a single line.">
  <div class="min-h-screen flex flex-col">
    <Header />
    <TabStrip active="minify" />
    <main class="flex-1 px-2 py-2 flex flex-col min-h-0">
      <Workspace tool="minify" client:load />
    </main>
    <Footer />
  </div>
</BaseLayout>
