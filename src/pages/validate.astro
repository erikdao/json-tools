---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TabStrip from '../components/TabStrip.astro';
import Workspace from '../components/Workspace';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Validate JSON — jsontools"
            description="Validate JSON and inspect its structure.">
  <div class="h-screen flex flex-col">
    <Header />
    <TabStrip active="validate" />
    <main class="flex-1 px-2 py-2 flex flex-col min-h-0">
      <Workspace tool="validate" client:load />
    </main>
    <Footer />
  </div>
</BaseLayout>
