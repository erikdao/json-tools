---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TabStrip from '../components/TabStrip.astro';
import Workspace from '../components/Workspace';
---
<BaseLayout title="Validate JSON — jsontools"
            description="Validate JSON and inspect its structure. Free, no tracking.">
  <div class="min-h-screen flex flex-col">
    <Header />
    <TabStrip active="validate" />
    <main class="flex-1 px-2 py-2">
      <Workspace tool="validate" client:load />
    </main>
    <Footer />
  </div>
</BaseLayout>
