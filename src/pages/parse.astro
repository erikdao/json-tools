---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TabStrip from '../components/TabStrip.astro';
import Workspace from '../components/Workspace';
---
<BaseLayout title="Parse JSON — jsontools"
            description="Parse JSON into an interactive tree.">
  <div class="min-h-screen flex flex-col">
    <Header />
    <TabStrip active="parse" />
    <main class="flex-1 px-2 py-2 flex flex-col min-h-0">
      <Workspace tool="parse" client:load />
    </main>
    <Footer />
  </div>
</BaseLayout>
