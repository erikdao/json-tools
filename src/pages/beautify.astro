---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TabStrip from '../components/TabStrip.astro';
---
<BaseLayout title="Beautify JSON — jsontools"
            description="Format and pretty-print JSON in your browser. Free, no tracking.">
  <div class="min-h-screen flex flex-col">
    <Header />
    <TabStrip active="beautify" />
    <main class="flex-1 px-2 py-2">
      <!-- Workspace island slotted in Task 19 -->
      <div id="workspace-root" data-tool="beautify"></div>
    </main>
    <Footer />
  </div>
</BaseLayout>
