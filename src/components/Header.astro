  <div class="flex items-center gap-4">
    <ThemeToggle client:load />
    <a href="https://github.com/erikdao/json-tools" rel="noopener"
       class="text-xs text-[var(--muted)] hover:text-[var(--amber)]">Source ↗</a>
  </div>
</header>
